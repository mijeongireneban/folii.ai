# Copy to .env.local and fill in. All five are required.

# Supabase project (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server-only; used by /api/chat and /api/wizard/parse)
OPENAI_API_KEY=

# Canonical origin. Local dev: http://localhost:3000. Prod: https://your-domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth (optional; enables "Connect GitHub" repo browser in Import)
# Create an OAuth App: github.com > Settings > Developer settings > OAuth Apps
# Callback URL: ${NEXT_PUBLIC_APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry (optional; error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
